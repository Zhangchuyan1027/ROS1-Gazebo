<launch>

  <arg name="slam_methods" default="gmapping" doc="slam type [gmapping, hector, karto, cartographer]"/>
  <arg name="open_rviz" default="true"/>
  <arg name="is_cartographer" value="$(eval slam_methods == 'cartographer')"/>


   <!--启用建图算法-->
  <include file="$(find robot_navigation)/launch/include/$(arg slam_methods).launch"/>

    <!-- rviz -->
  <group if="$(arg open_rviz)"> 
    <node pkg="rviz" type="rviz" name="rviz" required="true"
          args="-d $(find robot_navigation)/rviz/slam.rviz"/>
  </group>

</launch>



